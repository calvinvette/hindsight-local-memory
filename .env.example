# SQLite database path used by local Makefile and CLI workflows.
# Local values: ./.hindsight/hindsight.db, /absolute/path/to/hindsight.db
# Source: Project default used by demo and CLI examples.
HINDSIGHT_DB=./.hindsight/hindsight.db

# Environment label for local automation and CI-generated config.
# Local values: local, ci
# Source: Set to ci for CI helper config.
HINDSIGHT_ENV=local